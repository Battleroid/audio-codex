# Build output
bin/
obj/
publish/
*.user
.vs/

# Commercial fonts extracted from the game — not redistributed in source.
# The app falls back to a system font if these are absent; drop your own
# PP Fraktion Mono / MarathonShapiro OTFs here to restore the in-game look.
src/App/Assets/Fonts/*.otf

# Python reverse-engineering scratch (kept out of the C# repo)
*.py
mara/
__pycache__/

# Downloaded archive (the extracted tools/vgmstream/ folder is what's used)
tools/vgmstream.zip

# whisper.cpp binaries + model (large / third-party; fetched, not committed — see tools/whisper/README.md)
tools/whisper/*.exe
tools/whisper/*.dll
tools/whisper/*.bin
tools/whisper/*.zip

# DeepFilterNet denoiser binary (third-party; fetched, not committed)
tools/deepfilter/*.exe

# Parakeet / sherpa-onnx CUDA runtime + model (large; downloaded on first enable)
tools/parakeet/

# Logs
*.log

# Packaged release zips (build artifacts)
audio-codex-*.zip

# OS
Thumbs.db
.DS_Store
